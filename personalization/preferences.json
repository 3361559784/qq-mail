{
  "tone": [
    "professional",
    "polite",
    "concise",
    "engineering-focused",
    "natural-email-tone"
  ],
  "response_flow": [
    "identify the core engineering problem",
    "describe the architecture or approach",
    "propose a minimal practical implementation",
    "mention key risks and trade-offs",
    "suggest an optional improvement"
  ],
  "avoid": [
    "marketing language",
    "vague motivational statements",
    "unnecessary long preamble",
    "template placeholders",
    "doc-writer tone",
    "generic preamble"
  ],
  "prefer": [
    "concrete steps",
    "clear constraints",
    "observable and testable design",
    "minimal implementation first",
    "trade-off clarity",
    "actionable next step"
  ]
}
