QQ_EMAIL=your_qq_mail@qq.com
QQ_AUTH_CODE=qq_mail_smtp_imap_auth_code

GITHUB_TOKEN=ghp_or_github_pat_token
# 兼容旧配置：若仅设置 GITHUB_MODEL，也会自动作为主模型
GITHUB_MODEL=openai/gpt-4.1
GITHUB_MODEL_PRIMARY=openai/gpt-4.1
GITHUB_MODEL_FALLBACKS=openai/gpt-4o-mini,meta/llama-3.3-70b-instruct,mistral-ai/mistral-small-3.1
GITHUB_API_URL=https://models.github.ai/inference/chat/completions
MODEL_REQUEST_TIMEOUT_SECONDS=45
MODEL_SIGNATURE_TEMPLATE=--\\n使用 {model} 模型自动生成回复

IMAP_HOST=imap.qq.com
IMAP_PORT=993
SMTP_HOST=smtp.qq.com
SMTP_PORT=465

# 本地 CLI 轮询间隔（Functions Timer 不使用该值）
POLL_SECONDS=60
IMAP_FETCH_DAYS=1
MAX_INPUT_CHARS=4000
STATE_FILE=data/processed_messages.json
ALLOW_SENDERS_FILE=data/allow_senders.txt
DENY_SENDERS_FILE=data/deny_senders.txt
FREQUENT_SENDER_FILE=data/frequent_senders.json
FREQUENT_WINDOW_DAYS=30
FREQUENT_MIN_COUNT=3
FREQUENT_MAX_EVENTS=20
FILTER_LEVEL=medium
REPLY_SIGNATURE=--\\n这是一封自动回复邮件。
SELF_NOTIFY_ON_REPLY=true
# 为空则默认发到 QQ_EMAIL
SELF_NOTIFY_EMAIL=
SELF_NOTIFY_BODY_CHARS=1200

# Azure Functions Timer (UTC cron)
TIMER_SCHEDULE=0 */5 * * * *
# 本地/云端紧急关闭 Timer（云端仍推荐设置 AzureWebJobs.qq_mail_timer.Disabled=1）
QQ_MAIL_TIMER_DISABLED=false

# 状态存储: auto(优先Table,无连接串回退file) / table / file
STORAGE_BACKEND=auto
# 为空时回落读取 AzureWebJobsStorage
TABLE_CONNECTION_STRING=
PROCESSED_TABLE_NAME=processedstate
FREQUENT_TABLE_NAME=frequentsenderstate

# Workbench (local-first)
WORKBENCH_ENABLED=true
WORKBENCH_DB_PATH=data/workbench.db
WORKBENCH_ATTACH_DIR=data/attachments
WORKBENCH_ATTACH_MAX_MB=20
WORKBENCH_SYNC_DAYS_INITIAL=7
WORKBENCH_SYNC_INTERVAL_SECONDS=300
WORKBENCH_READ_ONLY=true
WORKBENCH_LLM_MODEL=openai/gpt-4o-mini
WORKBENCH_EMBED_MODEL=openai/text-embedding-3-small
WORKBENCH_LLM_ONLY_CANDIDATES=true
WORKBENCH_VECTOR_TOP_K=5
GITHUB_EMBEDDING_API_URL=https://models.github.ai/inference/embeddings
WORKBENCH_FAISS_INDEX_PATH=data/faiss.index
